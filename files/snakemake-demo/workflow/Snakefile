"""
Snakemake showcase workflow
============================
A small demonstration workflow that mirrors, step for step, the naive bash
pipeline in scripts/run_pipeline_bash_demo.sh:

    fastp -> FastQC -> SPAdes -> QUAST

It exists to show what the same four tools look like once they are wired
together with Snakemake instead of copy-pasted shell commands. It is not run
live during the workshop, but it is a complete, working workflow: given real
paired-end reads in resources/reads/ and the conda environments in
workflow/envs/, `snakemake --cores 10 --use-conda` will execute it end to end.
"""

configfile: "config/config.yaml"

SAMPLES = list(config["samples"].keys())

rule all:
    input:
        expand("results/qc_reports/{sample}_R1_fastqc.html", sample=SAMPLES),
        expand("results/qc_reports/{sample}_R2_fastqc.html", sample=SAMPLES),
        expand("results/quast/{sample}/report.pdf", sample=SAMPLES),
        "results/quast/summary.tsv",


rule fastp_trim:
    """Trim adapters and low-quality bases with fastp."""
    input:
        forward=lambda wildcards: config["samples"][wildcards.sample][0],
        rev=lambda wildcards: config["samples"][wildcards.sample][1],
    output:
        forward_trimmed=temp("results/trimmed/{sample}_R1.fastq.gz"),
        rev_trimmed=temp("results/trimmed/{sample}_R2.fastq.gz"),
        html=temp("results/trimmed/{sample}_fastp.html"),
        json=temp("results/trimmed/{sample}_fastp.json"),
    params:
        adapter=config["adapter_sequence"],
    log:
        "logs/fastp/{sample}.log",
    conda:
        "envs/trimming.yaml"
    threads: 4
    shell:
        """
        fastp -i {input.forward} -I {input.rev} \
            -o {output.forward_trimmed} -O {output.rev_trimmed} \
            --adapter_sequence {params.adapter} \
            --html {output.html} --json {output.json} \
            --thread {threads} \
            2> {log}
        """

rule fastqc:
    """Run FastQC on the trimmed reads."""
    input:
        forward="results/trimmed/{sample}_R1.fastq.gz",
        rev="results/trimmed/{sample}_R2.fastq.gz",
    output:
        "results/qc_reports/{sample}_R1_fastqc.zip",
        "results/qc_reports/{sample}_R2_fastqc.zip",
        "results/qc_reports/{sample}_R1_fastqc.html",
        "results/qc_reports/{sample}_R2_fastqc.html",
    log:
        "logs/fastqc/{sample}.log",
    conda:
        "envs/fastqc.yaml"
    threads: 2
    shell:
        """
        fastqc {input.forward} {input.rev} -o results/qc_reports/ -t {threads} 2> {log}
        """

rule spades_assembly:
    """Assemble the trimmed reads with SPAdes."""
    input:
        forward="results/trimmed/{sample}_R1.fastq.gz",
        rev="results/trimmed/{sample}_R2.fastq.gz",
    output:
        contigs="results/assembly/{sample}/contigs.fasta",
    params:
        outdir="results/assembly/{sample}",
        kmers=config["spades_kmers"],
    log:
        "logs/spades/{sample}.log",
    conda:
        "envs/genomics.yaml"
    threads: 8
    resources:
        mem_mb=8000,
    shell:
        """
        spades.py -1 {input.forward} -2 {input.rev} \
            -t {threads} -k {params.kmers} \
            -o {params.outdir} \
            2> {log}
        """


include: "rules/quast.smk"


